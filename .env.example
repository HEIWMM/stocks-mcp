# Tushare API Token
# 从 https://tushare.pro/ 获取
TUSHARE_TOKEN=your_token_here

# HTTP服务器端口（仅HTTP模式）
HTTP_PORT=3000

# MCP模式开关（true/false）
# 如果设置为true，将作为MCP服务器运行
# 如果设置为false或未设置，将作为HTTP服务器运行
MCP_MODE=false

# MCP HTTP传输模式（仅当MCP_MODE=true时有效）
# 如果设置为true，MCP服务器将使用Streamable HTTP传输（通过HTTP访问）
# 如果设置为false或未设置，MCP服务器将使用Stdio传输（标准输入输出）
MCP_HTTP=false
